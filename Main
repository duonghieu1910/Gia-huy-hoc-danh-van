<footer>Chạm vào chữ cái để ghép từ • Bé làm rất giỏi! 💛</footer>

<div class="celebrate" id="celebrate">
  <div class="celebrate-box">
    <div class="celebrate-emoji">🎉</div>
    <div class="celebrate-text" id="celebrateText">Giỏi quá!</div>
    <button class="ctrl-btn" id="nextBtn">Từ tiếp theo →</button>
  </div>
</div>

<script>
// ----- Dữ liệu từ vựng: emoji, từ, gợi ý âm -----
const WORDS = [
  { word: "CÁ",   emoji: "🐟" },
  { word: "GÀ",   emoji: "🐔" },
  { word: "CHÓ",  emoji: "🐶" },
  { word: "MÈO",  emoji: "🐱" },
  { word: "HOA",  emoji: "🌸" },
  { word: "XE",   emoji: "🚗" },
  { word: "NHÀ",  emoji: "🏠" },
  { word: "BÓNG", emoji: "⚽" },
  { word: "SAO",  emoji: "⭐" },
  { word: "ONG",  emoji: "🐝" },
  { word: "CUA",  emoji: "🦀" },
  { word: "VOI",  emoji: "🐘" },
];

let order = shuffle([...Array(WORDS.length).keys()]);
let currentIndex = 0;
let currentWord = "";
let answer = [];      // chữ cái đã đặt vào slot, theo thứ tự
let tilesState = [];  // trạng thái từng nút chữ cái (đã dùng hay chưa)
let starsEarned = 0;

const slotsEl = document.getElementById('slots');
const lettersEl = document.getElementById('letters');
const pictureEl = document.getElementById('picture');
const starsRow = document.getElementById('starsRow');
const celebrateEl = document.getElementById('celebrate');
const celebrateText = document.getElementById('celebrateText');

function shuffle(arr){
  for(let i = arr.length - 1; i > 0; i--){
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

function speak(text){
  if(!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'vi-VN';
  u.rate = 0.85;
  u.pitch = 1.05;
  const voices = window.speechSynthesis.getVoices();
  const viVoice = voices.find(v => v.lang && v.lang.toLowerCase().startsWith('vi'));
  if(viVoice) u.voice = viVoice;
  window.speechSynthesis.speak(u);
}

function playChime(success){
  try{
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const notes = success ? [523.25, 659.25, 783.99] : [300, 220];
    notes.forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.15, ctx.currentTime + i*0.12);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i*0.12 + 0.3);
      osc.connect(gain).connect(ctx.destination);
      osc.start(ctx.currentTime + i*0.12);
      osc.stop(ctx.currentTime + i*0.12 + 0.3);
    });
  }catch(e){ /* audio not available, ignore */ }
}

function renderStars(){
  starsRow.innerHTML = '';
  for(let i = 0; i < WORDS.length; i++){
    const s = document.createElement('span');
    s.className = 'star' + (i < starsEarned ? ' filled' : '');
    s.textContent = '⭐';
    starsRow.appendChild(s);
  }
}

function loadWord(){
  const data = WORDS[order[currentIndex]];
  currentWord = data.word;
  pictureEl.textContent = data.emoji;
  answer = new Array(currentWord.length).fill(null);

  // Render slots
  slotsEl.innerHTML = '';
  for(let i = 0; i < currentWord.length; i++){
    const slot = document.createElement('div');
    slot.className = 'slot';
    slot.dataset.index = i;
    slotsEl.appendChild(slot);
  }

  // Build shuffled letter set: correct letters + a couple distractors
  let letterPool = currentWord.split('');
  const distractorChoices = "ABEIOUKLMNRST".split('').filter(c => !letterPool.includes(c));
  shuffle(distractorChoices);
  const distractorCount = Math.min(2, distractorChoices.length);
  letterPool = letterPool.concat(distractorChoices.slice(0, distractorCount));
  letterPool = shuffle(letterPool);

  lettersEl.innerHTML = '';
  tilesState = letterPool.map((letter, idx) => ({ letter, used: false, id: idx }));
  tilesState.forEach(tile => {
    const btn = document.createElement('button');
    btn.className = 'tile';
    btn.textContent = tile.letter;
    btn.dataset.id = tile.id;
    btn.addEventListener('click', () => onTileClick(tile.id));
    lettersEl.appendChild(btn);
  });

  setTimeout(() => speak(currentWord), 400);
}

function onTileClick(tileId){
  const tile = tilesState.find(t => t.id === tileId);
  if(!tile || tile.used) return;

  const nextEmptyIndex = answer.findIndex(a => a === null);
  if(nextEmptyIndex === -1) return;

  answer[nextEmptyIndex] = tile.letter;
  tile.used = true;

  const btn = lettersEl.querySelector(`[data-id="${tileId}"]`);
  btn.classList.add('used');

  const slot = slotsEl.children[nextEmptyIndex];
  slot.textContent = tile.letter;
  slot.classList.add('filled');

  // Check if word is complete
  if(answer.every(a => a !== null)){
    setTimeout(checkAnswer, 300);
  }
}

function checkAnswer(){
  const built = answer.join('');
  if(built === currentWord){
    starsEarned = Math.min(starsEarned + 1, WORDS.length);
    renderStars();
    playChime(true);
    speak("Giỏi quá! " + currentWord);
    celebrateText.textContent = "Giỏi quá! Con ghép đúng từ " + currentWord;
    celebrateEl.classList.add('show');
    launchConfetti();
  } else {
    playChime(false);
    // shake wrong slots and reset
    Array.from(slotsEl.children).forEach(s => s.classList.add('wrong'));
    setTimeout(() => {
      Array.from(slotsEl.children).forEach(s => {
        s.classList.remove('wrong', 'filled');
        s.textContent = '';
      });
      answer = new Array(currentWord.length).fill(null);
      tilesState.forEach(t => t.used = false);
      lettersEl.querySelectorAll('.tile').forEach(b => b.classList.remove('used'));
    }, 500);
  }
}

function launchConfetti(){
  const colors = ['#FF6F59','#FFC93C','#3AA655','#6EC6E8','#FFFFFF'];
  for(let i = 0; i < 24; i++){
    const c = document.createElement('div');
    c.className = 'confetti';
    c.style.left = Math.random() * 100 + 'vw';
    c.style.background = colors[Math.floor(Math.random()*colors.length)];
    c.style.borderRadius = Math.random() > 0.5 ? '50%' : '3px';
    c.style.animationDuration = (2 + Math.random()*1.5) + 's';
    document.body.appendChild(c);
    setTimeout(() => c.remove(), 4000);
  }
}

document.getElementById('listenBtn').addEventListener('click', () => speak(currentWord));

document.getElementById('resetBtn').addEventListener('click', () => {
  Array.from(slotsEl.children).forEach(s => {
    s.classList.remove('filled', 'wrong');
    s.textContent = '';
  });
  answer = new Array(currentWord.length).fill(null);
  tilesState.forEach(t => t.used = false);
  lettersEl.querySelectorAll('.tile').forEach(b => b.classList.remove('used'));
});

document.getElementById('nextBtn').addEventListener('click', () => {
  celebrateEl.classList.remove('show');
  currentIndex = (currentIndex + 1) % order.length;
  if(currentIndex === 0){
    order = shuffle(order);
  }
  loadWord();
});

// Kick things off
renderStars();
loadWord();

// Some browsers load voices asynchronously
if('speechSynthesis' in window){
  window.speechSynthesis.onvoiceschanged = () => {};
}
</script>
</body>
</html>
